{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Termy Theme Metadata",
  "type": "object",
  "required": ["name", "slug", "latestVersion", "versions"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "description": { "type": "string" },
    "latestVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$" },
    "versions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "file", "checksumSha256"],
        "properties": {
          "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$" },
          "file": { "type": "string", "pattern": "^files/[A-Za-z0-9.+-]+\\.json$" },
          "changelog": { "type": "string" },
          "checksumSha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
